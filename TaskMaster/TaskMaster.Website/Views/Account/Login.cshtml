@{
    ViewData["Title"] = "Welcome Back";
    var returnUrl = ViewData["ReturnUrl"] as string ?? Url.Page("/Index");
}

<div class="tm-login-page d-flex align-items-center justify-content-center py-5">
    <div class="tm-login-card shadow rounded-4 bg-white" style="max-width: 520px; width: 100%; padding: 2.5rem 2.75rem;">
        <div class="text-center mb-4">
            <div class="mb-2">
                <span class="tm-logo__mark">TM</span>
            </div>
            <h1 class="h3 mb-1">Welcome Back</h1>
            <p class="text-muted mb-0">Please enter your details to sign in.</p>
        </div>

        <div class="d-flex gap-2 mb-3 justify-content-center">
            <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="d-flex gap-2">
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <button type="submit" name="provider" value="Google" class="btn btn-outline-secondary tm-social-btn">
                    <span class="tm-social-btn__avatar tm-social-btn--google">
                        <img src="https://img.icons8.com/color/48/google-logo.png" alt="Google" width="20" height="20" />
                    </span>
                    <span>Google</span>
                </button>
                <button type="submit" name="provider" value="GitHub" class="btn btn-outline-secondary tm-social-btn">
                    <span class="tm-social-btn__avatar tm-social-btn--github">
                        <img src="https://img.icons8.com/ios-glyphs/30/github.png" alt="GitHub" width="20" height="20" />
                    </span>
                    <span>GitHub</span>
                </button>
            </form>
        </div>

        <div class="text-center text-muted small mb-3">
            OR CONTINUE WITH USERNAME
        </div>

        <form asp-controller="Account" asp-action="Login" method="post" class="mb-3">
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input id="username" name="username" class="form-control" placeholder="e.g. admin" required />
            </div>

            <div class="mb-2">
                <div class="d-flex justify-content-between align-items-center">
                    <label for="password" class="form-label mb-0">Password</label>
                    <a href="#" class="small text-decoration-none">Forgot password?</a>
                </div>
                <input id="password" name="password" type="password" class="form-control" required />
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="rememberMe" checked />
                <label class="form-check-label small text-muted" for="rememberMe">
                    Keep me signed in for 30 days
                </label>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    Invalid username or password.
                </div>
            }

            <button type="submit" class="btn btn-primary w-100">
                Sign in to Dashboard
            </button>
        </form>

        <div class="text-center text-muted small">
            Don't have an account? <a href="#" class="text-decoration-none">Create account</a>
        </div>
    </div>
</div>

